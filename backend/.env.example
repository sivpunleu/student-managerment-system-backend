PORT=3000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/student_management
JWT_SECRET=replace_with_a_long_random_secret
JWT_ACCESS_EXPIRES_IN=1h
REFRESH_TOKEN_DAYS=30
CORS_ORIGIN=*
APP_TIME_ZONE=Asia/Bangkok

# Used only by: npm run create-admin
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password

# Used only by: npm run create-staff
STAFF_NAME=Academic Staff
STAFF_EMAIL=staff@example.com
STAFF_PASSWORD=change_this_password
